# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
docs/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
next-env.d.ts

# production
/build

# env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo

# qa screenshots and playwright artifacts
qa-*.png
.playwright-mcp/

# gstack session data
.gstack/

# misc
.DS_Store
*.pem
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# internal docs — not for public repo
pharmatrack_architecture.html
docs/*.html
docs/*.docx
docs/*.pdf
docs/auth-setup.md
docs/identify-malformed-qr-students.md
docs/supabase-outage-resilience.md
docs/superpowers/

# student sign-in data / generated attendance imports (contain PII — never commit)
docs/*.csv
scripts/import-orientation-attendance*.sql
scripts/RECONCILE-cpmt*.sql

# one-off scripts that look up/reconcile/verify real student records by name or
# email — incident-specific filenames (e.g. *-cpmt*.mjs) are too narrow to catch
# the next incident, so these are matched by the verb prefix instead. Scratch/
# scripts files are still free to use these names locally; they just won't be
# tracked.
scripts/reconcile-*.mjs
scratch/reconcile-*.mjs
scratch/verify-*.mjs
scratch/lookup-*.mjs
scratch/check-*.mjs
scratch/mark-*.mjs

# one-off incident writeups that tend to embed real student names/emails
docs/unresolved-attendees*.md
docs/attendance-incident-*.md
